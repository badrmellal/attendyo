# ===========================================================================
# ATTENDYO — environment. Copy to `.env` and adjust. Everything runs on your LAN.
# Nothing in here is sent to any cloud. One-time license, on-prem, CPU-friendly.
# ===========================================================================

# --- Attendyo Vision Engine runtime images (the recognition core) --------------
# Registry coordinates of the engine runtime images (implementation detail;
# third-party attribution lives in NOTICE).
registry=exadel/
POSTGRES_VERSION=1.2.0
ADMIN_VERSION=1.2.0
API_VERSION=1.2.0
FE_VERSION=1.2.0
# CPU build (works on any x86/ARM server, no GPU needed):
CORE_VERSION=1.2.0-mobilenet

# --- Postgres (shared by the vision engine + Attendyo app schema) ---------------
postgres_username=postgres
postgres_password=change-me-in-production
postgres_db=attendyo
postgres_domain=attendyo-postgres-db
postgres_port=5432

# --- Vision engine tuning (sane CPU defaults; raise for big sites) -----------
engine_admin_java_options=-Xmx2g
engine_api_java_options=-Xmx4g
uwsgi_processes=2
uwsgi_threads=2
save_images_to_db=true
max_file_size=10MB
max_request_size=20M
max_detect_size=1440
connection_timeout=10000
read_timeout=60000
enable_email_server=false

# --- Attendyo API ----------------------------------------------------------------
# Recognition API key: create a "Recognition" service in the vision engine
# console at :8000 (http://localhost:8000) and paste its key here.
ENGINE_API_KEY=00000000-0000-0000-0000-000000000002
ENGINE_URL=http://attendyo-engine-api:8080
ATTENDYO_JWT_SECRET=change-me-to-a-long-random-string
ATTENDYO_ADMIN_EMAIL=admin@attendyo.local
ATTENDYO_ADMIN_PASSWORD=attendyo-admin
ATTENDYO_DEVICE_KEY=change-me-device-shared-secret

# --- Console (Next.js) --------------------------------------------------------
# Browser talks to the API at this URL (default: published host port 8088).
NEXT_PUBLIC_API_URL=http://localhost:8088
