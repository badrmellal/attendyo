# ===========================================================================
# LIWAN — environment. Copy to `.env` and adjust. Everything runs on your LAN.
# Nothing in here is sent to any cloud. One-time license, on-prem, CPU-friendly.
# ===========================================================================

# --- CompreFace engine images (the recognition core, Apache-2.0) ------------
registry=exadel/
POSTGRES_VERSION=1.2.0
ADMIN_VERSION=1.2.0
API_VERSION=1.2.0
FE_VERSION=1.2.0
# CPU build (works on any x86/ARM server, no GPU needed):
CORE_VERSION=1.2.0-mobilenet

# --- Postgres (shared by CompreFace engine + Liwan app schema) --------------
postgres_username=postgres
postgres_password=change-me-in-production
postgres_db=liwan
postgres_domain=liwan-postgres-db
postgres_port=5432

# --- CompreFace tuning (sane CPU defaults; raise for big sites) -------------
compreface_admin_java_options=-Xmx2g
compreface_api_java_options=-Xmx4g
uwsgi_processes=2
uwsgi_threads=2
save_images_to_db=true
max_file_size=10MB
max_request_size=20M
max_detect_size=1440
connection_timeout=10000
read_timeout=60000
enable_email_server=false

# --- Liwan API --------------------------------------------------------------
# Recognition API key: create a "Recognition" service in the CompreFace UI
# (http://localhost:8000) and paste its key here.
COMPREFACE_API_KEY=00000000-0000-0000-0000-000000000002
COMPREFACE_API_URL=http://liwan-compreface-api:8080
LIWAN_JWT_SECRET=change-me-to-a-long-random-string
LIWAN_ADMIN_EMAIL=admin@liwan.local
LIWAN_ADMIN_PASSWORD=liwan-admin
LIWAN_DEVICE_KEY=change-me-device-shared-secret

# --- Console (Next.js) ------------------------------------------------------
# Browser talks to the API at this URL (default: published host port 8088).
NEXT_PUBLIC_API_URL=http://localhost:8088
