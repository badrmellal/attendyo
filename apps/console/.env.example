# ===========================================================================
# Liwan Console (Next.js) — environment
# ===========================================================================

# Base URL the browser uses to reach the Liwan API.
# In docker-compose this is the published host port (8088).
NEXT_PUBLIC_API_URL=http://localhost:8088

# Force the rich offline mock layer (no backend needed). Set to 1 for demos,
# reviews, or local design work. When unset/0 the app talks to the real API and
# only falls back to mock data if the API is unreachable.
NEXT_PUBLIC_MOCK=1
