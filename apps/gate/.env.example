# ===========================================================================
# ATTENDYO GATE — door kiosk environment. Copy to `.env.local` for local dev.
# Runs fully on your LAN. No cloud, no telemetry.
# ===========================================================================

# Attendyo API base (browser talks to it directly). Default published host port 8088.
NEXT_PUBLIC_API_URL=http://localhost:8088

# Device shared secret. Sent as `X-Device-Key` on POST /api/recognize.
# Must match ATTENDYO_DEVICE_KEY in the API's environment.
NEXT_PUBLIC_DEVICE_KEY=change-me-device-shared-secret

# Which camera this kiosk represents. Maps to a row in `attendyo.cameras`.
# Can also be overridden per-tablet via the ?camera=<uuid> query param.
NEXT_PUBLIC_CAMERA_ID=

# Optional: door this kiosk is mounted on. Maps to a row in `attendyo.doors`.
# Can also be overridden via the ?door=<uuid> query param.
NEXT_PUBLIC_DOOR_ID=

# MOCK mode: 1 = simulate recognitions on a timer (demo without camera/engine).
# Leave unset / 0 in production.
NEXT_PUBLIC_MOCK=0

# Spoken greeting via the browser's offline speechSynthesis (Smart Gate v2.1).
# ON by default; set 0 (or per-tablet ?voice=0) to silence a terminal.
NEXT_PUBLIC_VOICE=1

# WebAudio chime (two-note ding on granted, low tone on denied). ON by default;
# set 0 (or per-tablet ?sound=0) to disable.
NEXT_PUBLIC_SOUND=1
